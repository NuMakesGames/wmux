#!/usr/bin/env node
import crypto from "node:crypto";
import fs from "node:fs";
import http from "node:http";
import https from "node:https";
import net from "node:net";
import tls from "node:tls";
import { spawn } from "node:child_process";

const DEFAULT_PORT = 3490;
const DEFAULT_UPSTREAM = "http://127.0.0.1:8080";
const DEFAULT_SUNSHINE_URL = "https://127.0.0.1:47990";
const DEFAULT_SUNSHINE_HTTP_PORT = 47989;
const DEFAULT_SETUP_TIMEOUT_MS = 60_000;
const DEFAULT_TARGET_HEALTH_TIMEOUT_MS = 5_000;
const DEFAULT_MOONLIGHT_PAIR_DEVICE_NAME = "roth";
const DEFAULT_SUNSHINE_PIN_DELAY_MS = 3500;
const DEFAULT_MOONLIGHT_APP_TITLE = "Desktop";
const DEFAULT_MOONLIGHT_DATA_TRANSPORT = "auto";

const startedAt = new Date().toISOString();
const options = parseArgs(process.argv.slice(2));
const host = String(options.host || process.env.WMUX_MOONLIGHT_GATEWAY_HOST || "127.0.0.1");
const port = intOption(options.port || process.env.WMUX_MOONLIGHT_GATEWAY_PORT, DEFAULT_PORT);
const upstreamUrl = normalizeBaseUrl(String(options.upstream || process.env.WMUX_MOONLIGHT_WEB_URL || DEFAULT_UPSTREAM));
const upstream = new URL(upstreamUrl);
const managedBin = options.bin || process.env.WMUX_MOONLIGHT_WEB_BIN || "";
// When set, every gateway request (except health) must present this token via
// an Authorization: Bearer header or a ?token= query param. This closes the
// otherwise-unauthenticated proxy that hands out an authenticated Moonlight
// session. Left empty for backward compatibility with unconfigured setups.
const gatewayToken = String(options.token || process.env.WMUX_MOONLIGHT_GATEWAY_TOKEN || "").trim();
const gatewayCertFile = stringOption(options["cert-file"] || process.env.WMUX_MOONLIGHT_GATEWAY_CERT_FILE);
const gatewayKeyFile = stringOption(options["key-file"] || process.env.WMUX_MOONLIGHT_GATEWAY_KEY_FILE);
const gatewayTls = gatewayTlsOptions();
const gatewayProtocol = gatewayTls ? "https" : "http";
const targetHealthTimeoutMs = intOption(
  process.env.WMUX_MOONLIGHT_TARGET_HEALTH_TIMEOUT_MS,
  DEFAULT_TARGET_HEALTH_TIMEOUT_MS,
);
const disableAudioDecoder = boolOption(process.env.WMUX_MOONLIGHT_DISABLE_AUDIO_DECODER, false);
const managedArgs = [
  ...envArgs(process.env.WMUX_MOONLIGHT_WEB_ARGS),
  ...arrayOption(options["bin-arg"]),
];

assertSafeBindHost(host);

let managedProcess = null;
let managedExit = null;
let activeWebSockets = 0;
let moonlightSessionCookie = "";
let moonlightSessionExpiresAt = 0;
let moonlightSessionLoginPromise = null;

if (managedBin) {
  managedProcess = spawn(String(managedBin), managedArgs, {
    stdio: ["ignore", "inherit", "inherit"],
    env: process.env,
  });
  managedProcess.on("exit", (code, signal) => {
    managedExit = { code, signal, at: new Date().toISOString() };
    managedProcess = null;
  });
}

const server = (gatewayTls ? https.createServer(gatewayTls) : http.createServer());
server.on("request", (request, response) => {
  void handleRequest(request, response).catch((error) => {
    sendJson(response, 500, { error: "gateway_error", message: error instanceof Error ? error.message : String(error) });
  });
});

server.on("upgrade", (request, socket, head) => {
  void handleUpgrade(request, socket, head).catch((error) => {
    socket.write(`HTTP/1.1 502 Bad Gateway\r\ncontent-type: text/plain\r\n\r\n${error instanceof Error ? error.message : String(error)}`);
    socket.destroy();
  });
});

server.listen(port, host, () => {
  console.log(`wmux-moonlight-gateway listening on ${gatewayProtocol}://${host}:${port}`);
  console.log(`proxying Moonlight Web upstream at ${upstreamUrl}`);
});

process.on("SIGINT", shutdown);
process.on("SIGTERM", shutdown);

function gatewayAuthorized(request, url) {
  if (!gatewayToken) return true;
  const header = String(request.headers.authorization || "");
  const match = /^Bearer\s+(.+)$/i.exec(header.trim());
  const presented = (match ? match[1] : url.searchParams.get("token") || "").trim();
  if (!presented || presented.length !== gatewayToken.length) return false;
  return timingSafeEqualStr(presented, gatewayToken);
}

function timingSafeEqualStr(a, b) {
  const bufA = Buffer.from(a);
  const bufB = Buffer.from(b);
  if (bufA.length !== bufB.length) return false;
  return crypto.timingSafeEqual(bufA, bufB);
}

async function handleRequest(request, response) {
  const url = new URL(request.url || "/", `${gatewayProtocol}://${request.headers.host || `${host}:${port}`}`);
  if (url.pathname === "/api/wmux/health" && request.method === "GET") {
    sendJson(response, 200, await healthPayload());
    return;
  }
  if (!gatewayAuthorized(request, url)) {
    sendJson(response, 401, { error: "unauthorized" });
    return;
  }
  if (url.pathname === "/api/wmux/sessions" && request.method === "GET") {
    sendJson(response, 200, {
      sessions: [
        {
          id: "moonlight-web",
          state: activeWebSockets > 0 ? "active" : "idle",
          viewerCount: activeWebSockets,
          upstream: upstreamUrl,
        },
      ],
    });
    return;
  }
  if (url.pathname === "/api/wmux/config" && request.method === "GET") {
    sendJson(response, 200, {
      bind: { host, port, protocol: gatewayProtocol },
      upstream: upstreamUrl,
      managedProcess: processSummary(),
      setup: setupSummary(),
    });
    return;
  }
  if (url.pathname === "/api/wmux/login" && request.method === "GET") {
    await loginAndRedirect(request, response, url);
    return;
  }
  if (url.pathname === "/api/wmux/open" && request.method === "GET") {
    await openConfiguredHost(request, response, url);
    return;
  }
  if (url.pathname === "/api/wmux/setup/status" && request.method === "GET") {
    sendJson(response, 200, await setupStatus());
    return;
  }
  if (url.pathname === "/api/wmux/setup/pair" && request.method === "POST") {
    const body = await readJsonBody(request);
    sendJson(response, 200, await runPairSetup(body));
    return;
  }
  await proxyHttp(request, response);
}

async function healthPayload() {
  const setup = setupSummary();
  const [upstream, target] = await Promise.all([
    checkUpstream(),
    checkConfiguredTarget(setup),
  ]);
  return {
    ok: upstream.ok !== false && target.ok !== false,
    service: "wmux-moonlight-gateway",
    startedAt,
    bind: { host, port },
    protocol: gatewayProtocol,
    upstream,
    target,
    managedProcess: processSummary(),
    viewerCount: activeWebSockets,
    setup,
  };
}

function processSummary() {
  return {
    enabled: Boolean(managedBin),
    command: managedBin || undefined,
    args: managedArgs,
    pid: managedProcess?.pid,
    exited: managedExit,
  };
}

function setupSummary() {
  const launchSettings = moonlightLaunchSettings();
  return {
    moonlightWebConfigured: Boolean(process.env.WMUX_MOONLIGHT_WEB_USER && process.env.WMUX_MOONLIGHT_WEB_PASSWORD),
    sunshineConfigured: Boolean(process.env.WMUX_SUNSHINE_USER && process.env.WMUX_SUNSHINE_PASSWORD),
    sunshineUrl: process.env.WMUX_SUNSHINE_URL || DEFAULT_SUNSHINE_URL,
    moonlightHost: process.env.WMUX_MOONLIGHT_HOST || "127.0.0.1",
    moonlightHostId: intOption(process.env.WMUX_MOONLIGHT_HOST_ID, 0) || undefined,
    moonlightHostHttpPort: intOption(process.env.WMUX_MOONLIGHT_HOST_HTTP_PORT, DEFAULT_SUNSHINE_HTTP_PORT),
    moonlightPairDeviceName: process.env.WMUX_MOONLIGHT_PAIR_DEVICE_NAME || DEFAULT_MOONLIGHT_PAIR_DEVICE_NAME,
    moonlightAppTitle: process.env.WMUX_MOONLIGHT_APP_TITLE || DEFAULT_MOONLIGHT_APP_TITLE,
    moonlightAppId: intOption(process.env.WMUX_MOONLIGHT_APP_ID, 0) || undefined,
    moonlightDataTransport: launchSettings.dataTransport,
    moonlightLaunchSettings: launchSettings,
    moonlightTargetHealthTimeoutMs: targetHealthTimeoutMs,
    moonlightDisableAudioDecoder: disableAudioDecoder,
  };
}

async function setupStatus() {
  const setup = setupSummary();
  const [upstream, sunshine, target] = await Promise.all([
    checkUpstream(),
    checkSunshine(setup.sunshineUrl).catch((error) => ({
      ok: false,
      reason: error instanceof Error ? error.message : String(error),
    })),
    checkConfiguredTarget(setup),
  ]);
  return {
    ok: upstream.ok !== false && sunshine.ok !== false && target.ok !== false,
    setup,
    upstream,
    sunshine,
    target,
  };
}

async function runPairSetup(rawBody) {
  const body = rawBody && typeof rawBody === "object" ? rawBody : {};
  const moonlight = body.moonlight && typeof body.moonlight === "object" ? body.moonlight : {};
  const sunshine = body.sunshine && typeof body.sunshine === "object" ? body.sunshine : {};
  const moonlightUser = stringOption(moonlight.user || moonlight.username || process.env.WMUX_MOONLIGHT_WEB_USER);
  const moonlightPassword = stringOption(moonlight.password || process.env.WMUX_MOONLIGHT_WEB_PASSWORD);
  const sunshineUser = stringOption(sunshine.user || sunshine.username || process.env.WMUX_SUNSHINE_USER);
  const sunshinePassword = stringOption(sunshine.password || process.env.WMUX_SUNSHINE_PASSWORD);
  const sunshineUrl = normalizeBaseUrl(stringOption(sunshine.url || process.env.WMUX_SUNSHINE_URL || DEFAULT_SUNSHINE_URL));
  const moonlightHostAddress = stringOption(
    moonlight.host ||
      moonlight.address ||
      process.env.WMUX_MOONLIGHT_HOST ||
      stripBrackets(new URL(sunshineUrl).hostname) ||
      "127.0.0.1",
  );
  const moonlightHostHttpPort = intOption(
    moonlight.httpPort || moonlight.http_port || process.env.WMUX_MOONLIGHT_HOST_HTTP_PORT,
    DEFAULT_SUNSHINE_HTTP_PORT,
  );
  const moonlightPairDeviceName = stringOption(
    moonlight.pairDeviceName ||
      moonlight.pair_device_name ||
      process.env.WMUX_MOONLIGHT_PAIR_DEVICE_NAME ||
      DEFAULT_MOONLIGHT_PAIR_DEVICE_NAME,
  );
  const sunshinePinDelayMs = intOption(
    sunshine.pinDelayMs ||
      sunshine.pin_delay_ms ||
      body.sunshinePinDelayMs ||
      body.pinDelayMs ||
      process.env.WMUX_SUNSHINE_PIN_DELAY_MS,
    DEFAULT_SUNSHINE_PIN_DELAY_MS,
  );
  const insecure = boolOption(sunshine.insecure ?? process.env.WMUX_SUNSHINE_INSECURE, isLocalUrl(sunshineUrl));
  const timeoutMs = intOption(body.timeoutMs || process.env.WMUX_MOONLIGHT_SETUP_TIMEOUT_MS, DEFAULT_SETUP_TIMEOUT_MS);

  if (!moonlightUser || !moonlightPassword) {
    throw new Error("Moonlight Web credentials are required via request.moonlight or WMUX_MOONLIGHT_WEB_USER/WMUX_MOONLIGHT_WEB_PASSWORD");
  }
  if (!sunshineUser || !sunshinePassword) {
    throw new Error("Sunshine API credentials are required via request.sunshine or WMUX_SUNSHINE_USER/WMUX_SUNSHINE_PASSWORD");
  }

  const cookie = await moonlightLogin(moonlightUser, moonlightPassword);
  const hostResult = await ensureMoonlightHost(cookie, moonlightHostAddress, moonlightHostHttpPort);
  if (String(hostResult.host.paired) === "Paired") {
    return {
      ok: true,
      moonlight: {
        hostId: hostResult.host.host_id,
        hostName: hostResult.host.name,
        hostAddress: hostResult.host.address,
        hostHttpPort: hostResult.host.http_port,
        pairDeviceName: moonlightPairDeviceName,
        createdHost: hostResult.created,
        paired: true,
      },
      sunshine: {
        url: sunshineUrl,
        pinDelayMs: sunshinePinDelayMs,
        pinSubmitted: false,
      },
    };
  }
  const pairResult = await pairMoonlightHost({
    cookie,
    hostId: hostResult.host.host_id,
    sunshineUrl,
    sunshineUser,
    sunshinePassword,
    clientName: moonlightPairDeviceName,
    insecure,
    timeoutMs,
    sunshinePinDelayMs,
  });
  return {
    ok: true,
    moonlight: {
      hostId: hostResult.host.host_id,
      hostName: hostResult.host.name,
      hostAddress: hostResult.host.address,
      hostHttpPort: hostResult.host.http_port,
      pairDeviceName: moonlightPairDeviceName,
      createdHost: hostResult.created,
      paired: pairResult.paired,
    },
    sunshine: {
      url: sunshineUrl,
      pinDelayMs: sunshinePinDelayMs,
      pinSubmitted: pairResult.pinSubmitted,
    },
  };
}

async function moonlightLogin(name, password) {
  const response = await moonlightLoginResponse(name, password);
  const cookies = response.headers["set-cookie"] || [];
  const cookie = cookies.map((value) => String(value).split(";", 1)[0]).join("; ");
  if (!cookie) throw new Error("Moonlight Web login did not return a session cookie");
  return cookie;
}

async function moonlightLoginResponse(name, password) {
  return upstreamJsonRequest("/api/login", {
    method: "POST",
    json: { name, password },
    expectJson: false,
  });
}

async function authenticatedProxyCookie() {
  if (!process.env.WMUX_MOONLIGHT_WEB_USER || !process.env.WMUX_MOONLIGHT_WEB_PASSWORD) return "";
  const now = Date.now();
  if (moonlightSessionCookie && moonlightSessionExpiresAt - now > 60_000) return moonlightSessionCookie;
  if (!moonlightSessionLoginPromise) {
    moonlightSessionLoginPromise = refreshMoonlightSessionCookie().finally(() => {
      moonlightSessionLoginPromise = null;
    });
  }
  return moonlightSessionLoginPromise;
}

async function refreshMoonlightSessionCookie() {
  const login = await moonlightLoginResponse(process.env.WMUX_MOONLIGHT_WEB_USER, process.env.WMUX_MOONLIGHT_WEB_PASSWORD);
  const cookies = Array.isArray(login.headers["set-cookie"]) ? login.headers["set-cookie"] : [];
  const session = cookies.find((cookie) => /^mlSession=/i.test(String(cookie)));
  if (!session) throw new Error("Moonlight Web login did not return mlSession");
  moonlightSessionCookie = String(session).split(";", 1)[0];
  moonlightSessionExpiresAt = cookieExpiresAt(session) ?? Date.now() + 12 * 60 * 60 * 1000;
  return moonlightSessionCookie;
}

async function loginAndRedirect(request, response, url) {
  const next = safeRedirectPath(url.searchParams.get("next") || "/");
  const moonlightUser = stringOption(process.env.WMUX_MOONLIGHT_WEB_USER);
  const moonlightPassword = stringOption(process.env.WMUX_MOONLIGHT_WEB_PASSWORD);
  if (!moonlightUser || !moonlightPassword) {
    response.writeHead(302, {
      location: next,
      "cache-control": "no-store",
    });
    response.end();
    return;
  }
  const login = await moonlightLoginResponse(moonlightUser, moonlightPassword);
  const cookies = Array.isArray(login.headers["set-cookie"]) ? login.headers["set-cookie"] : [];
  const session = cookies.find((cookie) => /^mlSession=/i.test(String(cookie)));
  if (session) {
    moonlightSessionCookie = String(session).split(";", 1)[0];
    moonlightSessionExpiresAt = cookieExpiresAt(session) ?? Date.now() + 12 * 60 * 60 * 1000;
  }
  response.writeHead(302, {
    location: next,
    "cache-control": "no-store",
    ...(cookies.length ? { "set-cookie": cookies.map((cookie) => normalizeGatewaySetCookie(cookie, isSecureRequest(request))) } : {}),
  });
  response.end();
}

async function openConfiguredHost(request, response, url) {
  const cookie = await authenticatedProxyCookie();
  const directHostId = intOption(url.searchParams.get("hostId") || url.searchParams.get("host_id") || process.env.WMUX_MOONLIGHT_HOST_ID, 0);
  const requestedAppId = intOption(url.searchParams.get("appId") || url.searchParams.get("app_id") || process.env.WMUX_MOONLIGHT_APP_ID, 0);
  if (!cookie && (!directHostId || !requestedAppId)) {
    response.writeHead(302, {
      location: "/",
      "cache-control": "no-store",
    });
    response.end();
    return;
  }
  const hostId = directHostId || await resolveConfiguredMoonlightHost(cookie, url);
  const appId = requestedAppId || await resolveMoonlightAppId(cookie, hostId, requestedMoonlightAppTitle(url));
  const next = `/stream.html?hostId=${encodeURIComponent(hostId)}&appId=${encodeURIComponent(appId)}`;
  sendHtml(response, 200, streamLaunchPage(next));
}

async function resolveConfiguredMoonlightHost(cookie, url) {
  const sunshineUrl = normalizeBaseUrl(stringOption(url.searchParams.get("sunshineUrl") || process.env.WMUX_SUNSHINE_URL || DEFAULT_SUNSHINE_URL));
  const moonlightHostAddress = stringOption(
    url.searchParams.get("host") ||
      url.searchParams.get("address") ||
      process.env.WMUX_MOONLIGHT_HOST ||
      stripBrackets(new URL(sunshineUrl).hostname) ||
      "127.0.0.1",
  );
  const moonlightHostHttpPort = intOption(
    url.searchParams.get("httpPort") || url.searchParams.get("http_port") || process.env.WMUX_MOONLIGHT_HOST_HTTP_PORT,
    DEFAULT_SUNSHINE_HTTP_PORT,
  );
  const hostResult = await ensureMoonlightHost(cookie, moonlightHostAddress, moonlightHostHttpPort);
  return hostResult.host.host_id;
}

function requestedMoonlightAppTitle(url) {
  return stringOption(
    url.searchParams.get("appTitle") ||
      url.searchParams.get("app") ||
      process.env.WMUX_MOONLIGHT_APP_TITLE ||
      DEFAULT_MOONLIGHT_APP_TITLE,
  );
}

async function resolveMoonlightAppId(cookie, hostId, title) {
  const response = await upstreamJsonRequest(`/api/apps?host_id=${encodeURIComponent(hostId)}`, {
    method: "GET",
    cookie,
  });
  const apps = Array.isArray(response.body?.apps) ? response.body.apps : [];
  const normalizedTitle = String(title || "").trim().toLowerCase();
  const selected =
    apps.find((app) => String(app.title || "").trim().toLowerCase() === normalizedTitle) ||
    apps.find((app) => String(app.title || "").trim().toLowerCase() === DEFAULT_MOONLIGHT_APP_TITLE.toLowerCase()) ||
    apps[0];
  const appId = Number(selected?.app_id ?? selected?.id);
  if (!Number.isFinite(appId) || appId <= 0) {
    throw new Error(`Moonlight app ${title || DEFAULT_MOONLIGHT_APP_TITLE} was not found`);
  }
  return appId;
}

async function ensureMoonlightHost(cookie, address, httpPort) {
  const existing = await findMoonlightHost(cookie, address, httpPort);
  if (existing) return { created: false, host: existing };
  const response = await upstreamJsonRequest("/api/host", {
    method: "POST",
    cookie,
    json: { address, http_port: httpPort },
  });
  return { created: true, host: response.body.host };
}

async function findMoonlightHost(cookie, address, httpPort) {
  const initial = await upstreamNdjsonInitial("/api/hosts", { method: "GET", cookie });
  const hosts = Array.isArray(initial?.hosts) ? initial.hosts : [];
  for (const host of hosts) {
    if (!Number.isFinite(host?.host_id)) continue;
    const detail = await upstreamJsonRequest(`/api/host?host_id=${encodeURIComponent(host.host_id)}`, {
      method: "GET",
      cookie,
    }).catch(() => null);
    const detailedHost = detail?.body?.host;
    if (!detailedHost) continue;
    if (String(detailedHost.address).toLowerCase() === String(address).toLowerCase() && Number(detailedHost.http_port) === Number(httpPort)) {
      return detailedHost;
    }
  }
  return null;
}

async function pairMoonlightHost({ cookie, hostId, sunshineUrl, sunshineUser, sunshinePassword, clientName, insecure, timeoutMs, sunshinePinDelayMs }) {
  return new Promise((resolve, reject) => {
    let resolved = false;
    let buffered = "";
    let pinSubmitted = false;
    let pairedObserved = false;
    let pinPromise = null;
    let pairRequest;
    const timeout = setTimeout(() => {
      if (pairRequest) pairRequest.destroy(new Error("Moonlight pairing timed out"));
      reject(new Error("Moonlight pairing timed out"));
    }, timeoutMs);

    const finish = (value) => {
      if (resolved) return;
      resolved = true;
      clearTimeout(timeout);
      resolve(value);
    };
    const fail = (error) => {
      if (resolved) return;
      resolved = true;
      clearTimeout(timeout);
      reject(error);
    };
    const finishPaired = () => {
      pairedObserved = true;
      if (!pinPromise) {
        finish({ paired: true, pinSubmitted });
        return;
      }
      pinPromise
        .then(() => finish({ paired: true, pinSubmitted }))
        .catch(fail);
    };

    pairRequest = upstreamRawRequest("/api/pair", {
      method: "POST",
      cookie,
      json: { host_id: hostId },
    }, (response) => {
      if (!response.ok) {
        fail(new Error(`Moonlight Web pair returned HTTP ${response.statusCode}`));
        response.resume();
        return;
      }
      response.setEncoding("utf8");
      response.on("data", (chunk) => {
        buffered += chunk;
        const lines = buffered.split("\n");
        buffered = lines.pop() || "";
        for (const line of lines) {
          if (!line.trim()) continue;
          let message;
          try {
            message = JSON.parse(line);
          } catch (error) {
            fail(error);
            return;
          }
          if (typeof message === "string") {
            if (message === "PairError") fail(new Error("Moonlight Web pairing failed"));
            continue;
          }
          if (message.Pin) {
            pinPromise = sleep(sunshinePinDelayMs)
              .then(() => submitSunshinePin({
                sunshineUrl,
                username: sunshineUser,
                password: sunshinePassword,
                pin: String(message.Pin),
                clientName,
                insecure,
              }))
              .then(() => {
                pinSubmitted = true;
              })
              .catch(fail);
          } else if (message.Paired) {
            finishPaired();
          } else if (message.PairError) {
            fail(new Error("Moonlight Web pairing failed"));
          }
        }
      });
      response.on("end", () => {
        if (!resolved && !pairedObserved) fail(new Error("Moonlight Web pairing ended before completion"));
      });
      response.on("error", fail);
    });
    pairRequest.on("error", fail);
  });
}

async function submitSunshinePin({ sunshineUrl, username, password, pin, clientName, insecure }) {
  const response = await urlJsonRequest(sunshineUrl, "/api/pin", {
    method: "POST",
    json: { pin, name: clientName },
    basicAuth: { username, password },
    insecure,
  });
  if (response.body?.status === false) {
    throw new Error("Sunshine rejected the submitted PIN");
  }
}

async function checkSunshine(sunshineUrl) {
  const response = await urlJsonRequest(sunshineUrl, "/api/configLocale", {
    method: "GET",
    insecure: boolOption(process.env.WMUX_SUNSHINE_INSECURE, isLocalUrl(sunshineUrl)),
    expectJson: false,
    timeoutMs: 1_500,
  });
  return { ok: response.statusCode >= 200 && response.statusCode < 500, status: response.statusCode };
}

async function checkConfiguredTarget(setup) {
  let hostId = setup.moonlightHostId;
  const appId = setup.moonlightAppId;
  try {
    const cookie = await authenticatedProxyCookie();
    if (!hostId) {
      if (!cookie) {
        return {
          ok: false,
          reason: "Moonlight Web credentials or WMUX_MOONLIGHT_HOST_ID are required for target health checks",
        };
      }
      const hostResult = await ensureMoonlightHost(cookie, setup.moonlightHost, setup.moonlightHostHttpPort);
      hostId = Number(hostResult.host?.host_id);
    }
    if (!Number.isFinite(hostId) || hostId <= 0) {
      return { ok: false, reason: "Moonlight host id is not configured" };
    }
    await upstreamJsonRequest(`/api/host?host_id=${encodeURIComponent(hostId)}`, {
      method: "GET",
      cookie,
      expectJson: false,
      timeoutMs: targetHealthTimeoutMs,
    });
    if (appId) {
      await upstreamJsonRequest(`/api/apps?host_id=${encodeURIComponent(hostId)}`, {
        method: "GET",
        cookie,
        expectJson: false,
        timeoutMs: targetHealthTimeoutMs,
      });
    }
    return {
      ok: true,
      hostId,
      appId: appId || undefined,
    };
  } catch (error) {
    return {
      ok: false,
      hostId: hostId || undefined,
      appId: appId || undefined,
      reason: describeTargetError(error, setup),
    };
  }
}

function describeTargetError(error, setup) {
  const message = error instanceof Error ? error.message : String(error);
  const target = `${setup.moonlightHost}:${setup.moonlightHostHttpPort}`;
  if (/connection\s*refused|connectionre|code:\s*111|tcp connect error/i.test(message)) {
    return `Moonlight Web cannot reach Sunshine at ${target} (connection refused)`;
  }
  if (/timed out|timeout/i.test(message)) {
    return `Moonlight Web target check timed out for ${target}`;
  }
  return `Moonlight target check failed for ${target}: ${message.slice(0, 180)}`;
}

function proxyHttp(request, response) {
  return new Promise((resolve, reject) => {
    const target = targetUrl(request.url || "/");
    const client = target.protocol === "https:" ? https : http;
    const injectAudioDecoderShim = shouldInjectAudioDecoderShim(request, target);
    authenticatedProxyHeaders(request.headers, target)
      .then((headers) => {
        if (injectAudioDecoderShim) {
          delete headers["accept-encoding"];
        }
        const proxyRequest = client.request(
          target,
          {
            method: request.method,
            headers,
          },
          (proxyResponse) => {
            if (injectAudioDecoderShim && isHtmlResponse(proxyResponse)) {
              const chunks = [];
              proxyResponse.on("data", (chunk) => chunks.push(Buffer.from(chunk)));
              proxyResponse.on("end", () => {
                const html = Buffer.concat(chunks).toString("utf8");
                const body = injectAudioDecoderShimHtml(html);
                response.writeHead(proxyResponse.statusCode || 502, responseHeaders(proxyResponse.headers, { generatedBody: true }));
                response.end(body);
                resolve();
              });
              proxyResponse.on("error", reject);
              return;
            }
            response.writeHead(proxyResponse.statusCode || 502, responseHeaders(proxyResponse.headers));
            proxyResponse.pipe(response);
            proxyResponse.on("end", resolve);
          },
        );
        proxyRequest.on("error", (error) => {
          if ((request.url || "/") === "/") {
            response.writeHead(200, { "content-type": "text/html; charset=utf-8", "cache-control": "no-store" });
            response.end(fallbackPage(error));
          } else {
            sendJson(response, 502, {
              error: "upstream_unavailable",
              upstream: upstreamUrl,
              message: error instanceof Error ? error.message : String(error),
            });
          }
          resolve();
        });
        request.pipe(proxyRequest);
      })
      .catch(reject);
  });
}

function shouldInjectAudioDecoderShim(request, target) {
  return disableAudioDecoder &&
    request.method === "GET" &&
    target.pathname.replace(/\/+$/, "") === "/stream.html";
}

function isHtmlResponse(response) {
  return String(response.headers["content-type"] || "").toLowerCase().includes("text/html");
}

function injectAudioDecoderShimHtml(html) {
  const marker = "</head>";
  const shim = `<script>
(() => {
  try {
    const unsupportedAudioDecoder = { isConfigSupported: async () => ({ supported: false }) };
    Object.defineProperty(window, "AudioDecoder", {
      configurable: true,
      writable: true,
      value: unsupportedAudioDecoder,
    });
  } catch {
    try {
      window.AudioDecoder = { isConfigSupported: async () => ({ supported: false }) };
    } catch {}
  }
})();
</script>`;
  if (html.includes(marker)) return html.replace(marker, `${shim}\n${marker}`);
  return `${shim}\n${html}`;
}

async function handleUpgrade(request, socket, head) {
  if (request.url && request.url.startsWith("/api/wmux/")) {
    socket.write("HTTP/1.1 404 Not Found\r\n\r\n");
    socket.destroy();
    return;
  }
  const upgradeUrl = new URL(request.url || "/", `${gatewayProtocol}://${request.headers.host || `${host}:${port}`}`);
  if (!gatewayAuthorized(request, upgradeUrl)) {
    socket.write("HTTP/1.1 401 Unauthorized\r\n\r\n");
    socket.destroy();
    return;
  }
  activeWebSockets += 1;
  socket.on("close", () => {
    activeWebSockets = Math.max(0, activeWebSockets - 1);
  });
  await proxyUpgrade(request, socket, head);
}

async function proxyUpgrade(request, clientSocket, head) {
  const target = targetUrl(request.url || "/");
  const port = Number(target.port || (target.protocol === "https:" ? 443 : 80));
  const connect = target.protocol === "https:" ? tls.connect : net.connect;
  const headers = await authenticatedProxyHeaders(request.headers, target);
  let upgraded = false;
  let closed = false;
  const upstreamSocket = connect({ host: target.hostname, port, servername: target.hostname }, () => {
    if (closed) return;
    upgraded = true;
    const path = `${target.pathname}${target.search}`;
    try {
      upstreamSocket.write(`${request.method} ${path} HTTP/${request.httpVersion}\r\n`);
      for (const [name, value] of Object.entries(headers)) {
        if (Array.isArray(value)) {
          for (const item of value) upstreamSocket.write(`${name}: ${item}\r\n`);
        } else if (value !== undefined) {
          upstreamSocket.write(`${name}: ${value}\r\n`);
        }
      }
      upstreamSocket.write("\r\n");
      if (head.length) upstreamSocket.write(head);
    } catch {
      closeTunnel();
      return;
    }
    clientSocket.pipe(upstreamSocket);
    upstreamSocket.pipe(clientSocket);
  });

  function closeTunnel() {
    if (closed) return;
    closed = true;
    clientSocket.destroy();
    upstreamSocket.destroy();
  }

  upstreamSocket.on("error", () => {
    if (!upgraded && !clientSocket.destroyed && clientSocket.writable) {
      try {
        clientSocket.write("HTTP/1.1 502 Bad Gateway\r\n\r\n");
      } catch {
        // The client may already be gone; the tunnel cleanup below is enough.
      }
    }
    closeTunnel();
  });
  clientSocket.on("error", closeTunnel);
  upstreamSocket.on("close", closeTunnel);
  clientSocket.on("close", closeTunnel);
}

function targetUrl(rawPath) {
  const incoming = new URL(rawPath, "http://wmux-moonlight-gateway.local");
  const target = new URL(upstreamUrl);
  const prefix = target.pathname.replace(/\/+$/, "");
  target.pathname = `${prefix}/${incoming.pathname.replace(/^\/+/, "")}`;
  target.search = incoming.search;
  return target;
}

async function authenticatedProxyHeaders(headers, target) {
  const sessionCookie = await authenticatedProxyCookie();
  return {
    ...headers,
    host: target.host,
    ...(sessionCookie ? { cookie: mergeCookieHeader(headers.cookie, sessionCookie) } : {}),
  };
}

function responseHeaders(headers, options = {}) {
  const copy = { ...headers };
  delete copy["x-frame-options"];
  delete copy["content-security-policy"];
  if (options.generatedBody) {
    delete copy["content-length"];
    delete copy["content-encoding"];
    delete copy.etag;
    delete copy["last-modified"];
    copy["cache-control"] = "no-store";
  }
  return copy;
}

function checkUpstream() {
  return new Promise((resolve) => {
    const target = targetUrl("/");
    const client = target.protocol === "https:" ? https : http;
    const request = client.request(
      target,
      { method: "GET", headers: { host: target.host }, timeout: 1200 },
      (response) => {
        response.resume();
        resolve({ ok: response.statusCode ? response.statusCode < 500 : false, status: response.statusCode });
      },
    );
    request.on("timeout", () => {
      request.destroy(new Error("upstream health check timed out"));
    });
    request.on("error", (error) => {
      resolve({ ok: false, reason: error instanceof Error ? error.message : String(error) });
    });
    request.end();
  });
}

function upstreamRawRequest(pathname, options, onResponse) {
  return rawJsonRequest(targetUrl(pathname), options, onResponse);
}

async function upstreamJsonRequest(pathname, options = {}) {
  return urlJsonRequest(upstreamUrl, pathname, options);
}

async function upstreamNdjsonInitial(pathname, options = {}) {
  return new Promise((resolve, reject) => {
    let buffered = "";
    let settled = false;
    const request = upstreamRawRequest(pathname, options, (response) => {
      if (!response.ok) {
        settled = true;
        reject(new Error(`Moonlight Web returned HTTP ${response.statusCode}`));
        response.resume();
        return;
      }
      response.setEncoding("utf8");
      response.on("data", (chunk) => {
        if (settled) return;
        buffered += chunk;
        const newline = buffered.indexOf("\n");
        if (newline < 0) return;
        const line = buffered.slice(0, newline).trim();
        settled = true;
        request.destroy();
        try {
          resolve(line ? JSON.parse(line) : null);
        } catch (error) {
          reject(error);
        }
      });
      response.on("end", () => {
        if (settled) return;
        settled = true;
        try {
          resolve(buffered.trim() ? JSON.parse(buffered.trim()) : null);
        } catch (error) {
          reject(error);
        }
      });
      response.on("error", (error) => {
        if (!settled) reject(error);
      });
    });
    request.on("error", (error) => {
      if (!settled && error.message !== "socket hang up") reject(error);
    });
  });
}

async function urlJsonRequest(baseUrl, pathname, options = {}) {
  return new Promise((resolve, reject) => {
    let body = "";
    const request = rawJsonRequest(buildUrl(baseUrl, pathname), options, (response) => {
      response.setEncoding("utf8");
      response.on("data", (chunk) => {
        body += chunk;
      });
      response.on("end", () => {
        let parsed = null;
        if (options.expectJson !== false && body.trim()) {
          try {
            parsed = JSON.parse(body);
          } catch (error) {
            reject(error);
            return;
          }
        }
        if (response.statusCode < 200 || response.statusCode >= 300) {
          reject(new Error(`HTTP ${response.statusCode}${body ? `: ${body.slice(0, 200)}` : ""}`));
          return;
        }
        resolve({
          statusCode: response.statusCode,
          headers: response.headers,
          body: parsed,
          text: body,
        });
      });
      response.on("error", reject);
    });
    request.on("error", reject);
  });
}

function rawJsonRequest(target, options = {}, onResponse) {
  const client = target.protocol === "https:" ? https : http;
  const jsonBody = options.json === undefined ? null : JSON.stringify(options.json);
  const headers = {
    accept: options.expectJson === false ? "*/*" : "application/json, application/x-ndjson",
    ...(options.cookie ? { cookie: options.cookie } : {}),
    ...(jsonBody ? { "content-type": "application/json", "content-length": Buffer.byteLength(jsonBody) } : {}),
    ...(options.basicAuth ? { authorization: basicAuthHeader(options.basicAuth.username, options.basicAuth.password) } : {}),
    ...(options.headers || {}),
  };
  const request = client.request(
    target,
    {
      method: options.method || "GET",
      headers,
      rejectUnauthorized: target.protocol === "https:" ? !options.insecure : undefined,
    },
    (response) => {
      response.ok = Boolean(response.statusCode && response.statusCode >= 200 && response.statusCode < 300);
      onResponse(response);
    },
  );
  if (options.timeoutMs) {
    request.setTimeout(Number(options.timeoutMs), () => {
      request.destroy(new Error(`request timed out after ${Number(options.timeoutMs)}ms`));
    });
  }
  if (jsonBody) request.write(jsonBody);
  request.end();
  return request;
}

function buildUrl(baseUrl, pathname) {
  const target = new URL(normalizeBaseUrl(baseUrl));
  const incoming = new URL(pathname, "http://wmux-moonlight-gateway.local");
  const prefix = target.pathname.replace(/\/+$/, "");
  target.pathname = `${prefix}/${incoming.pathname.replace(/^\/+/, "")}`;
  target.search = incoming.search;
  return target;
}

function basicAuthHeader(username, password) {
  return `Basic ${Buffer.from(`${username}:${password}`, "utf8").toString("base64")}`;
}

function readJsonBody(request) {
  return new Promise((resolve, reject) => {
    const chunks = [];
    request.on("data", (chunk) => chunks.push(Buffer.from(chunk)));
    request.on("end", () => {
      const raw = Buffer.concat(chunks).toString("utf8").trim();
      if (!raw) {
        resolve({});
        return;
      }
      try {
        resolve(JSON.parse(raw));
      } catch (error) {
        reject(error);
      }
    });
    request.on("error", reject);
  });
}

function fallbackPage(error) {
  const escapedError = escapeHtml(error instanceof Error ? error.message : String(error));
  const escapedUpstream = escapeHtml(upstreamUrl);
  return `<!doctype html>
<html>
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>wmux Moonlight Gateway</title>
    <style>
      html, body { height: 100%; margin: 0; background: #050505; color: #f4efe1; font: 13px ui-monospace, SFMono-Regular, Menlo, Consolas, monospace; }
      body { display: grid; place-items: center; padding: 24px; box-sizing: border-box; }
      main { max-width: 760px; border: 1px solid #6f5a2b; padding: 22px; background: #0b0b0a; }
      h1 { margin: 0 0 12px; color: #f0c86a; font-size: 15px; letter-spacing: .08em; text-transform: uppercase; }
      p { line-height: 1.55; color: #b9ad97; }
      code { color: #f4efe1; }
    </style>
  </head>
  <body>
    <main>
      <h1>Moonlight upstream unavailable</h1>
      <p>The gateway is running, but it cannot reach <code>${escapedUpstream}</code>.</p>
      <p>Run Moonlight Web Stream on this host, or start this gateway with <code>WMUX_MOONLIGHT_WEB_URL</code> pointing at an existing instance. Sunshine must be installed and paired from the Moonlight Web UI.</p>
      <p><code>${escapedError}</code></p>
    </main>
  </body>
</html>`;
}

function streamLaunchPage(next) {
  const settings = moonlightLaunchSettings();
  return `<!doctype html>
<html>
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Opening Stream</title>
    <script>
      (() => {
        const next = ${JSON.stringify(next)};
        const settingsPatch = ${JSON.stringify(settings)};
        try {
          const raw = localStorage.getItem("mlSettings");
          const existing = raw ? JSON.parse(raw) : {};
          const effectiveSettings = { ...settingsPatch };
          if (!window.isSecureContext && effectiveSettings.canvasRenderer === true) {
            effectiveSettings.canvasRenderer = false;
          }
          localStorage.setItem("mlSettings", JSON.stringify(mergeSettings(existing, effectiveSettings)));
        } catch {}
        location.replace(next);
        function mergeSettings(target, patch) {
          const output = { ...(target && typeof target === "object" ? target : {}) };
          for (const [key, value] of Object.entries(patch)) {
            if (value && typeof value === "object" && !Array.isArray(value)) {
              output[key] = mergeSettings(output[key], value);
            } else {
              output[key] = value;
            }
          }
          return output;
        }
      })();
    </script>
  </head>
  <body>
    <a href="${escapeHtml(next)}">Open stream</a>
  </body>
</html>`;
}

function sendHtml(response, status, html) {
  response.writeHead(status, { "content-type": "text/html; charset=utf-8", "cache-control": "no-store" });
  response.end(html);
}

function sendJson(response, status, payload) {
  response.writeHead(status, { "content-type": "application/json", "cache-control": "no-store" });
  response.end(JSON.stringify(payload));
}

function normalizeBaseUrl(value) {
  const parsed = new URL(value);
  if (parsed.protocol !== "http:" && parsed.protocol !== "https:") {
    throw new Error("WMUX_MOONLIGHT_WEB_URL must be http or https");
  }
  return parsed.toString().replace(/\/+$/, "");
}

function parseArgs(argv) {
  const result = {};
  for (let index = 0; index < argv.length; index += 1) {
    const arg = argv[index];
    if (!arg.startsWith("--")) continue;
    const body = arg.slice(2);
    const equals = body.indexOf("=");
    const key = equals >= 0 ? body.slice(0, equals) : body;
    const value = equals >= 0 ? body.slice(equals + 1) : argv[index + 1]?.startsWith("--") ? "true" : argv[++index] || "true";
    if (result[key] === undefined) {
      result[key] = value;
    } else if (Array.isArray(result[key])) {
      result[key].push(value);
    } else {
      result[key] = [result[key], value];
    }
  }
  return result;
}

function arrayOption(value) {
  if (value === undefined) return [];
  return Array.isArray(value) ? value.map(String) : [String(value)];
}

function envArgs(value) {
  if (!value) return [];
  const trimmed = value.trim();
  if (!trimmed) return [];
  if (trimmed.startsWith("[")) {
    const parsed = JSON.parse(trimmed);
    return Array.isArray(parsed) ? parsed.map(String) : [];
  }
  return trimmed.split(/\s+/);
}

function intOption(value, fallback) {
  const parsed = Number.parseInt(String(value || ""), 10);
  return Number.isFinite(parsed) && parsed > 0 ? parsed : fallback;
}

function stringOption(value) {
  return typeof value === "string" && value.trim() ? value.trim() : "";
}

function boolOption(value, fallback = false) {
  if (value === undefined || value === null || value === "") return fallback;
  if (typeof value === "boolean") return value;
  const text = String(value).trim().toLowerCase();
  if (["1", "true", "yes", "on"].includes(text)) return true;
  if (["0", "false", "no", "off"].includes(text)) return false;
  return fallback;
}

function gatewayTlsOptions() {
  if (!gatewayCertFile && !gatewayKeyFile) return null;
  if (!gatewayCertFile || !gatewayKeyFile) {
    throw new Error("Both WMUX_MOONLIGHT_GATEWAY_CERT_FILE and WMUX_MOONLIGHT_GATEWAY_KEY_FILE are required for HTTPS");
  }
  return {
    cert: fs.readFileSync(gatewayCertFile),
    key: fs.readFileSync(gatewayKeyFile),
  };
}

function moonlightDataTransport() {
  const value = stringOption(process.env.WMUX_MOONLIGHT_DATA_TRANSPORT || DEFAULT_MOONLIGHT_DATA_TRANSPORT).toLowerCase();
  return ["auto", "webrtc", "websocket"].includes(value) ? value : DEFAULT_MOONLIGHT_DATA_TRANSPORT;
}

function moonlightLaunchSettings() {
  const jsonSettings = jsonObjectOption(process.env.WMUX_MOONLIGHT_SETTINGS_JSON);
  const settings = {
    ...jsonSettings,
    dataTransport: moonlightDataTransport(),
  };
  assignIntSetting(settings, "bitrate", envIntOption("WMUX_MOONLIGHT_BITRATE_KBPS", "WMUX_MOONLIGHT_BITRATE"));
  assignIntSetting(settings, "fps", envIntOption("WMUX_MOONLIGHT_FPS"));
  assignIntSetting(settings, "videoFrameQueueSize", envIntOption("WMUX_MOONLIGHT_VIDEO_FRAME_QUEUE_SIZE"));
  assignIntSetting(settings, "audioSampleQueueSize", envIntOption("WMUX_MOONLIGHT_AUDIO_SAMPLE_QUEUE_SIZE"));
  assignEnumSetting(settings, "videoSize", process.env.WMUX_MOONLIGHT_VIDEO_SIZE, ["720p", "1080p", "1440p", "4k", "native", "custom"]);
  assignEnumSetting(settings, "videoCodec", process.env.WMUX_MOONLIGHT_VIDEO_CODEC, ["auto", "h264", "h265", "av1"]);
  assignBoolSetting(settings, "canvasRenderer", envBoolOption("WMUX_MOONLIGHT_CANVAS_RENDERER"));
  assignBoolSetting(settings, "canvasVsync", envBoolOption("WMUX_MOONLIGHT_CANVAS_VSYNC"));
  assignBoolSetting(settings, "forceVideoElementRenderer", envBoolOption("WMUX_MOONLIGHT_FORCE_VIDEO_ELEMENT_RENDERER"));
  assignBoolSetting(settings, "playAudioLocal", envBoolOption("WMUX_MOONLIGHT_PLAY_AUDIO_LOCAL"));
  const width = envIntOption("WMUX_MOONLIGHT_VIDEO_WIDTH");
  const height = envIntOption("WMUX_MOONLIGHT_VIDEO_HEIGHT");
  if (width || height) {
    const existingCustom = settings.videoSizeCustom && typeof settings.videoSizeCustom === "object" ? settings.videoSizeCustom : {};
    settings.videoSizeCustom = {
      ...existingCustom,
      ...(width ? { width } : {}),
      ...(height ? { height } : {}),
    };
    if (width && height && !settings.videoSize) settings.videoSize = "custom";
  }
  return settings;
}

function jsonObjectOption(value) {
  if (!value) return {};
  try {
    const parsed = JSON.parse(String(value));
    return parsed && typeof parsed === "object" && !Array.isArray(parsed) ? parsed : {};
  } catch {
    return {};
  }
}

function assignIntSetting(settings, key, value) {
  if (value) settings[key] = value;
}

function assignEnumSetting(settings, key, value, allowed) {
  const normalized = stringOption(value).toLowerCase();
  if (allowed.includes(normalized)) settings[key] = normalized;
}

function assignBoolSetting(settings, key, value) {
  if (value !== undefined) settings[key] = value;
}

function envIntOption(...names) {
  for (const name of names) {
    const value = process.env[name];
    if (value === undefined || value === null || value === "") continue;
    const parsed = Number.parseInt(String(value), 10);
    if (Number.isFinite(parsed) && parsed > 0) return parsed;
  }
  return undefined;
}

function envBoolOption(name) {
  const value = process.env[name];
  if (value === undefined || value === null || value === "") return undefined;
  const text = String(value).trim().toLowerCase();
  if (["1", "true", "yes", "on"].includes(text)) return true;
  if (["0", "false", "no", "off"].includes(text)) return false;
  return undefined;
}

function sleep(ms) {
  return new Promise((resolve) => setTimeout(resolve, ms));
}

function safeRedirectPath(value) {
  if (!value || !value.startsWith("/") || value.startsWith("//")) return "/";
  if (value.startsWith("/api/wmux/login")) return "/";
  return value;
}

function normalizeGatewaySetCookie(value, secureRequest) {
  const parts = String(value)
    .split(";")
    .map((part) => part.trim())
    .filter(Boolean);
  const cookie = parts.shift();
  if (!cookie) return "";
  let hasPath = false;
  const attrs = [];
  for (const attr of parts) {
    if (/^domain=/i.test(attr)) continue;
    if (/^secure$/i.test(attr) && !secureRequest) continue;
    if (/^path=/i.test(attr)) {
      hasPath = true;
      attrs.push("Path=/");
      continue;
    }
    attrs.push(attr);
  }
  if (!hasPath) attrs.push("Path=/");
  return [cookie, ...attrs].join("; ");
}

function isSecureRequest(request) {
  const forwardedProto = String(request.headers["x-forwarded-proto"] || "").split(",", 1)[0].trim().toLowerCase();
  if (forwardedProto === "https") return true;
  return Boolean(request.socket.encrypted);
}

function mergeCookieHeader(existing, sessionCookie) {
  const raw = Array.isArray(existing) ? existing.join("; ") : String(existing || "");
  const cookies = raw
    .split(";")
    .map((part) => part.trim())
    .filter(Boolean)
    .filter((part) => !/^mlSession=/i.test(part));
  cookies.push(sessionCookie);
  return cookies.join("; ");
}

function cookieExpiresAt(setCookie) {
  const match = String(setCookie).match(/;\s*expires=([^;]+)/i);
  if (!match) return null;
  const value = Date.parse(match[1]);
  return Number.isFinite(value) ? value : null;
}

function stripBrackets(value) {
  return String(value || "").replace(/^\[/, "").replace(/\]$/, "");
}

function isLocalUrl(value) {
  try {
    const hostname = stripBrackets(new URL(value).hostname).toLowerCase();
    if (hostname === "localhost" || hostname === "127.0.0.1" || hostname === "::1") return true;
    if (hostname.startsWith("127.")) return true;
    return false;
  } catch {
    return false;
  }
}

function assertSafeBindHost(value) {
  if (value === "localhost") return;
  const version = net.isIP(value);
  if (!version) throw new Error(`Refusing to bind to non-IP host ${value}; use a loopback, Tailscale, or RFC1918 address`);
  if (version === 4 && isSafeIpv4(value)) return;
  if (version === 6 && isSafeIpv6(value)) return;
  throw new Error(`Refusing to bind wmux-moonlight-gateway to public address ${value}`);
}

function isSafeIpv4(value) {
  const [a, b] = value.split(".").map((part) => Number.parseInt(part, 10));
  if (a === 127) return true;
  if (a === 10) return true;
  if (a === 100 && b >= 64 && b <= 127) return true;
  if (a === 172 && b >= 16 && b <= 31) return true;
  if (a === 192 && b === 168) return true;
  if (a === 169 && b === 254) return true;
  return false;
}

function isSafeIpv6(value) {
  const normalized = value.toLowerCase();
  return normalized === "::1" || normalized.startsWith("fc") || normalized.startsWith("fd") || normalized.startsWith("fe80:");
}

function escapeHtml(value) {
  return value
    .replace(/&/g, "&amp;")
    .replace(/</g, "&lt;")
    .replace(/>/g, "&gt;")
    .replace(/"/g, "&quot;");
}

function shutdown() {
  server.close(() => process.exit(0));
  if (managedProcess) managedProcess.kill("SIGTERM");
  setTimeout(() => process.exit(0), 1500).unref();
}
