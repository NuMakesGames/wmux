#!/usr/bin/env node
// Sets the wmux browser login credentials in ~/.wmux/auth.json.
//
// Usage:
//   wmux-set-password                     # prompts for username + password
//   wmux-set-password --username alice    # prompts for password only
//   WMUX_PASSWORD=secret wmux-set-password --username alice   # non-interactive
//
// A running wmux server must be restarted after this file is updated. The
// helper prints the exact systemd command instead of restarting automatically,
// because it may itself be running inside a wmux-owned terminal session.
import crypto from "node:crypto";
import fs from "node:fs";
import os from "node:os";
import path from "node:path";
import readline from "node:readline";
import { StringDecoder } from "node:string_decoder";

const authPath = process.env.WMUX_AUTH_PATH || path.join(os.homedir(), ".wmux", "auth.json");

const argFor = (name) => {
  const index = process.argv.indexOf(name);
  return index === -1 ? undefined : process.argv[index + 1];
};

const hashPassword = (password) => {
  const salt = crypto.randomBytes(16);
  const derived = crypto.scryptSync(password, salt, 32);
  return `scrypt$${salt.toString("hex")}$${derived.toString("hex")}`;
};

const promptVisible = (question) =>
  new Promise((resolve) => {
    const rl = readline.createInterface({ input: process.stdin, output: process.stdout, terminal: true });
    rl.question(question, (answer) => {
      rl.close();
      resolve(answer);
    });
  });

const promptHidden = (question) =>
  new Promise((resolve, reject) => {
    const input = process.stdin;
    if (!input.isTTY || typeof input.setRawMode !== "function") {
      const rl = readline.createInterface({ input, output: process.stdout, terminal: false });
      rl.question(question, (answer) => {
        rl.close();
        resolve(answer);
      });
      return;
    }

    const wasRaw = Boolean(input.isRaw);
    const decoder = new StringDecoder("utf8");
    let answer = "";
    let settled = false;

    const restoreTerminal = () => {
      try {
        input.setRawMode(wasRaw);
      } catch {
        // The TTY may already have closed.
      }
    };
    const cleanup = () => {
      input.off("data", onData);
      input.off("error", onError);
      process.off("exit", restoreTerminal);
      restoreTerminal();
      input.pause();
    };
    const finish = () => {
      if (settled) return;
      settled = true;
      cleanup();
      process.stdout.write("\n");
      resolve(answer);
    };
    const cancel = () => {
      if (settled) return;
      settled = true;
      cleanup();
      process.stdout.write("\n");
      const error = new Error("password entry cancelled");
      error.code = "WMUX_PROMPT_CANCELLED";
      reject(error);
    };
    const onError = (error) => {
      if (settled) return;
      settled = true;
      cleanup();
      reject(error);
    };
    function onData(chunk) {
      for (const character of decoder.write(chunk)) {
        if (character === "\u0003") {
          cancel();
          return;
        }
        if (character === "\r" || character === "\n") {
          finish();
          return;
        }
        if (character === "\b" || character === "\u007f") {
          const characters = Array.from(answer);
          if (characters.length > 0) {
            characters.pop();
            answer = characters.join("");
            process.stdout.write("\b \b");
          }
          continue;
        }
        if (character.codePointAt(0) < 0x20) continue;
        answer += character;
        process.stdout.write("*");
      }
    }

    input.on("data", onData);
    input.on("error", onError);
    process.once("exit", restoreTerminal);
    input.setRawMode(true);
    input.resume();
    process.stdout.write(question);
  });

const main = async () => {
  const username = argFor("--username") || process.env.WMUX_USERNAME || (await promptVisible("Username: ")) || "wmux";
  const password =
    process.env.WMUX_PASSWORD || (await promptHidden("Password: "));
  if (!password) {
    console.error("wmux-set-password: password must not be empty");
    process.exit(1);
  }

  const record = { username: username.trim(), passwordHash: hashPassword(password) };
  fs.mkdirSync(path.dirname(authPath), { recursive: true });
  fs.writeFileSync(authPath, `${JSON.stringify(record, null, 2)}\n`, { mode: 0o600 });
  console.log(`wmux: updated login for '${record.username}' in ${authPath}`);
  console.log("wmux: restart the running server to load the new credentials.");
  console.log("wmux: systemd user service: systemctl --user restart wmux.service");
};

void main().catch((error) => {
  if (error?.code === "WMUX_PROMPT_CANCELLED") {
    process.exitCode = 130;
    return;
  }
  console.error(`wmux-set-password: ${error instanceof Error ? error.message : String(error)}`);
  process.exitCode = 1;
});
