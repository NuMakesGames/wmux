#!/usr/bin/env python3
import argparse
import json
import os
import sys
import urllib.request


def _wmux_token():
    token = os.environ.get("WMUX_TOKEN")
    if token:
        return token
    # Fall back to the server's local token file so hooks in existing/durable
    # local panes authenticate even when WMUX_TOKEN was never in their env.
    path = os.environ.get("WMUX_TOKEN_PATH") or os.path.expanduser("~/.wmux/token")
    try:
        with open(path, "r", encoding="utf-8") as handle:
            return handle.read().strip()
    except OSError:
        return ""


def _wmux_auth_headers():
    token = _wmux_token()
    return {"authorization": "Bearer " + token} if token else {}


command_name = os.environ.get("WMUX_COPY_PROG") or os.path.basename(sys.argv[0]) or "wmux-copy"


def read_input(path: str | None) -> str:
    if path:
        with open(path, "rb") as handle:
            data = handle.read()
    else:
        if sys.stdin.isatty():
            raise ValueError(f"{command_name} requires stdin or a file")
        data = sys.stdin.buffer.read()
    return data.decode("utf-8", errors="replace")


parser = argparse.ArgumentParser(prog=command_name)
parser.add_argument("--url", default=os.environ.get("WMUX_URL", "http://127.0.0.1:3478"))
parser.add_argument("--pane", default=os.environ.get("WMUX_PANE_ID", ""))
parser.add_argument("--workspace", default=os.environ.get("WMUX_WORKSPACE_ID", ""))
parser.add_argument("--tab", default=os.environ.get("WMUX_TAB_ID", ""))
parser.add_argument("file", nargs="?")
args = parser.parse_args()

try:
    text = read_input(args.file)
except ValueError as error:
    parser.error(str(error))

if not text:
    print(f"{command_name}: no input", file=sys.stderr)
    sys.exit(2)

payload = {"text": text}
if args.pane:
    payload["paneId"] = args.pane
if args.workspace:
    payload["workspaceId"] = args.workspace
if args.tab:
    payload["tabId"] = args.tab

request = urllib.request.Request(
    args.url.rstrip("/") + "/api/clipboard",
    data=json.dumps(payload).encode("utf-8"),
    headers={"content-type": "application/json", **_wmux_auth_headers()},
    method="POST",
)
with urllib.request.urlopen(request, timeout=15):
    pass
