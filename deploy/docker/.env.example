# Docker publishes wmux on host loopback by default. Set this to a specific
# Tailscale or RFC1918 address only when clients connect directly to this host.
WMUX_PUBLISH_HOST=127.0.0.1
WMUX_PUBLISH_PORT=3478
WMUX_PORT=3478

# Set WMUX_PUBLIC_URL whenever clients connect outside the Docker network. It
# must be reachable from this container and every managed remote machine.
# Direct private-network example: http://100.64.0.10:3478
# WMUX_PUBLIC_URL=https://wmux.example.internal
# WMUX_ALLOWED_HOSTS is also required for reverse-proxy or non-*.ts.net names.
# WMUX_ALLOWED_HOSTS=wmux.example.internal
# Features that use forwarded client addresses require the proxy's exact IP as
# observed inside this container. Re-check the Docker network gateway after any
# network recreation. Never use a wildcard, hostname, or CIDR.
# WMUX_TRUSTED_PROXIES=172.20.0.1

# Leave WMUX_HOST unset to select the container's private default-route address.
# An explicit value must be a non-loopback Tailscale, RFC1918, or IPv6 ULA
# address assigned inside the container.
# WMUX_HOST=172.20.0.2

# wmux generates and persists a token on first start when this is unset.
# WMUX_TOKEN=replace-with-a-long-random-value
# WMUX_DISABLE_AUTH=1
